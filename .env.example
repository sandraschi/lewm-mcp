# Auto-discovered if D:\Dev\repos\external\le-wm exists
LEWM_UPSTREAM_ROOT=D:\Dev\repos\external\le-wm
LEWM_STABLEWM_HOME=D:\Dev\repos\external\le-wm\.stable-wm
LEWM_DEVICE=cuda:0
LEWM_DEFAULT_DATA=pusht
LEWM_DEFAULT_POLICY=pusht/lewm
LEWM_DEFAULT_EVAL_CONFIG=pusht.yaml
LEWM_SINGLE_GPU_LOCK=1
# Set LEWM_DRY_RUN=1 to build commands without spawning GPU jobs (tests)
# LEWM_DRY_RUN=0
